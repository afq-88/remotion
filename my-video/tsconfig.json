{
  "compilerOptions": {
    "lib": ["dom", "esnext"],
    "module": "esnext",
    "target": "es6",
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "remotion.config.ts"],
  "exclude": ["node_modules"]
}
